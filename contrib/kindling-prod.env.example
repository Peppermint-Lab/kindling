# Production environment for Kindling (sourced by /usr/local/lib/kindling/serve.sh).
# Copy to /etc/kindling/kindling.env and adjust. Owner root:your-service-user, chmod 640.

# IPv4/hostname shown in direct runtime URLs (must reach this host).
KINDLING_ADVERTISE_HOST=203.0.113.50

# GitHub webhooks + dashboard + edge TLS for the control plane hostname.
# Use https:// and a real DNS name (not a bare IP). The Kindling edge will terminate TLS for
# this host and proxy to the API on 127.0.0.1:8080. Example:
#   https://app.kindling.systems
# For HTTP-only or IP-only, use http://203.0.113.50:8080 (no automatic TLS on the API host).
KINDLING_PUBLIC_URL=https://app.kindling.systems

KINDLING_HOME=/home/ubuntu/kindling
KINDLING_LISTEN=:8080
KINDLING_EDGE_HTTP=:80
KINDLING_EDGE_HTTPS=:443

# Let's Encrypt contact for TLS on custom app domains (edge :443). Use a real inbox.
KINDLING_ACME_EMAIL=you@example.com

# Optional: uncomment for LE staging while testing DNS.
# KINDLING_ACME_STAGING=1
