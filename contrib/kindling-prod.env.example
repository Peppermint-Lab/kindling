# Production environment for Kindling (sourced by /usr/local/lib/kindling/serve.sh).
# Copy to /etc/kindling/kindling.env and adjust. Owner root:your-service-user, chmod 640.

# IPv4/hostname shown in direct runtime URLs (must reach this host).
KINDLING_ADVERTISE_HOST=203.0.113.50

# Public API base (Connect/meta, webhooks). Use https:// and a real DNS name.
# Edge terminates TLS for this host and proxies to 127.0.0.1:8080. Example:
#   https://api.kindling.systems
KINDLING_PUBLIC_URL=https://api.kindling.systems

# Dashboard SPA hostname (no scheme). Same edge → same loopback; Host header selects SPA vs API.
# Example: app.kindling.systems
KINDLING_DASHBOARD_HOST=app.kindling.systems

KINDLING_HOME=/home/ubuntu/kindling
KINDLING_LISTEN=:8080
KINDLING_EDGE_HTTP=:80
KINDLING_EDGE_HTTPS=:443
KINDLING_CH_STATE_DIR=/data/kindling-runtime/cloud-hypervisor
# Recommended for systemd-managed production so restarts fully clean up child bridge/VM helpers.
KINDLING_PRESERVE_WORKLOADS_ON_SHUTDOWN=0

# Optional networking overrides for TAP-backed microVM egress.
# Defaults cover the current cloud-hypervisor deployment TAPs (`kch+`) and CI runner TAPs (`kci+`).
# KINDLING_VM_EGRESS_IFACE=eno1
# KINDLING_VM_EGRESS_CIDRS=10.0.0.0/8
# KINDLING_VM_TAP_PREFIXES=kch+,kci+

# Let's Encrypt contact for TLS on custom app domains (edge :443). Use a real inbox.
KINDLING_ACME_EMAIL=you@example.com

# Optional: uncomment for LE staging while testing DNS.
# KINDLING_ACME_STAGING=1

# Optional but recommended for first public bootstrap: remote account creation requires this token.
# Without it, bootstrap is allowed only from loopback/local access to the API host.
# KINDLING_BOOTSTRAP_TOKEN=replace-with-a-long-random-secret

# Optional: comma-separated extra Allowed-Origins for credentialed API calls (login cookies).
# Usually not needed: the server already allows configured origins plus localhost only when
# the API itself is running on localhost for local development.
# KINDLING_CORS_ORIGINS=https://another-dashboard-origin.example.com
